    "from sklearn.discriminant_analysis import LinearDiscriminantAnalysis\n",
    "import matplotlib.pyplot as plt\n",
    "import pandas as pd\n",
    "\n",
    "df = pd.read_csv(r\"C:\\Users\\MI\\data set\\11.04.2026\\lda_gaussian.csv\")\n",
    "X= df[['Feature1','Feature2']]\n",
    "y= df['Label']\n",
    "\n",
    "lda = LinearDiscriminantAnalysis()\n",
    "x_proj = lda.fit_transform(X,y)\n",
    "\n",
    "plt.hist(x_proj[y==0], alpha =0.5, label ='class 0')\n",
    "plt.hist(x_proj [y==1], alpha =0.5, label = 'class 1')\n",
    "plt.legend()\n",
    "plt.xlabel('LDA projection 1D')\n",
    "plt.ylabel('Frequency')\n",
    "plt.title('LDA projection')\n",
    "plt.show()\n",
    "         \n",
    "\n"
   ]
